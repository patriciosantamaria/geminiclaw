# Ignore media and download files
/srv/media/
/srv/downloads/
/srv/backups/

# Ignore massive app data volumes
/srv/app_data/home-server/immich/
/srv/app_data/home-server/immich_postgres/
/srv/app_data/home-server/firefly_db/
/srv/app_data/home-server/prometheus/
/srv/app_data/home-server/plex/
/srv/app_data/home-server/grafana/
/srv/app_data/home-server/adguardhome/
/srv/app_data/home-server/bazarr/
/srv/app_data/home-server/tdarr_cache/

# Ignore old/obsolete app data
/srv/app_data/home-server/mcp-hub/
/srv/app_data/ai-workspace/adk/

# Ignore database files project-wide
/srv/app_data/home-server/firefly_imports/*.xml
**/*.db
**/*.db-shm
**/*.db-wal
**/*.sqlite
**/*.xml

# Ignore caches and temporary data
**/cache/
**/Cache/
**/logs/
**/Logs/
**/*.log
**/*.pid
**/MediaCover/
**/Backups/
**/Sentry/

# Node internals
node_modules/
dist/

# Binaries
/srv/docker/mcp-server/op
/srv/docker/mcp-server/op.sig
