FROM node:20-alpine

# Install Docker CLI, dependencies, and shadow for user management
RUN apk add --no-cache docker-cli curl unzip shadow bash sqlite

# Set UID/GID for node user (ensure it matches 1000)
RUN usermod -u 1000 node && groupmod -g 1000 node || true

# Copy 1Password CLI from build context
COPY op /usr/local/bin/op
RUN chmod +x /usr/local/bin/op

# Install global MCP servers
RUN npm install -g @modelcontextprotocol/server-sequential-thinking @modelcontextprotocol/server-github @upstash/context7-mcp

# Patch Sequential Thinking
RUN sed -i "/Sequential Thinking MCP Server running on stdio/d" /usr/local/lib/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js

WORKDIR /app/home-server-ts

# Start the application using tsx for on-the-fly execution since it is mounted
CMD ["npx", "tsx", "src/index.ts"]
