FROM node:20-alpine

# Install curl, unzip, and bash
RUN apk add --no-cache curl unzip bash jq

# Copy 1Password CLI
COPY op /usr/local/bin/op
RUN chmod +x /usr/local/bin/op

WORKDIR /app

# Copy package files
COPY package*.json ./
RUN npm install

# Copy source
COPY . .
RUN npm run build

# Keep container alive for on-demand tool execution via docker exec
CMD ["tail", "-f", "/dev/null"]
