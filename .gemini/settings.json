      "command": "/app/wizard-bridge-mcp/wizard-bridge-wrapper.sh",
      "args": [],
      "trust": true
    },
    "github": {
      "command": "/app/github-mcp-wrapper.sh",
      "args": [],
      "trust": true,
      "includeTools": [
        "get_pull_request",
        "list_pull_requests",
        "get_pull_request_files",
        "get_pull_request_status",
        "get_pull_request_comments",
        "get_pull_request_reviews",
        "get_file_contents",
        "list_commits",
        "merge_pull_request"
